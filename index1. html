<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Control de Tarjeta Pro</title>
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#ff6b35">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/sql-wasm.js"></script>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body { background: #0f1419; color: #e8eef5; font-family: 'Plus Jakarta Sans', sans-serif; }
    .card-surface { background: #1a2028; border: 1px solid rgba(255,255,255,0.06); }
    .accent-btn { background: #ff6b35; color: #0f1419; font-weight: 700; }
    .input-field { background: #1a2028; border: 1px solid rgba(255,255,255,0.1); color: #e8eef5; outline: none; }
    .input-field:focus { border-color: #ff6b35; }
  </style>
</head>
<body class="p-4 pb-20">
  <header class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-[#ff6b35]">Mi Tarjeta</h1>
    <div class="flex gap-2">
       <button onclick="exportarDB()" class="p-2 card-surface rounded-lg text-xs">💾 Exportar</button>
       <button onclick="document.getElementById('file-input').click()" class="p-2 card-surface rounded-lg text-xs">📂 Abrir</button>
       <input type="file" id="file-input" class="hidden" accept=".db">
    </div>
  </header>

  <div id="status-db" class="text-[10px] text-center mb-2 opacity-50">Conectando base de datos...</div>

  <div class="card-surface rounded-2xl p-5 mb-6 text-center">
    <div class="flex justify-between items-center mb-4">
      <button onclick="cambiarMes(-1)" class="p-2"><i data-lucide="chevron-left"></i></button>
      <h2 id="current-month-label" class="text-lg font-semibold capitalize">---</h2>
      <button onclick="cambiarMes(1)" class="p-2"><i data-lucide="chevron-right"></i></button>
    </div>
    <div class="text-xs text-gray-400 mb-1">TOTAL DEL MES</div>
    <div id="month-total" class="text-4xl font-bold text-[#ff6b35]">$0.00</div>
  </div>

  <form id="expense-form" class="card-surface rounded-2xl p-5 mb-6 space-y-4">
    <input id="desc" type="text" placeholder="¿Qué compraste?" required class="input-field w-full p-3 rounded-xl">
    <div class="grid grid-cols-2 gap-4">
      <input id="amount" type="number" step="0.01" placeholder="Monto Total" required class="input-field p-3 rounded-xl">
      <input id="installments" type="number" placeholder="Cuotas" value="1" required class="input-field p-3 rounded-xl">
    </div>
    <input id="start-date" type="month" required class="input-field w-full p-3 rounded-xl">
    <button type="submit" class="accent-btn w-full p-4 rounded-xl shadow-lg shadow-[#ff6b35]/20">Guardar Gasto</button>
  </form>

  <div id="expenses-list" class="space-y-3"></div>

  <script>
    let db;
    let viewDate = new Date(); viewDate.setDate(1);

    async function iniciar() {
      const status = document.getElementById('status-db');
      try {
        const SQL = await initSqlJs({ locateFile: file => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/${file}` });
        const saved = localStorage.getItem("db_tarjeta");
        
        if (saved) {
          db = new SQL.Database(new Uint8Array(JSON.parse(saved)));
          status.innerText = "✅ Base de datos cargada";
        } else {
          db = new SQL.Database();
          db.run("CREATE TABLE IF NOT EXISTS gastos (id INTEGER PRIMARY KEY, desc TEXT, monto REAL, cuotas INTEGER, inicio TEXT)");
          status.innerText = "🆕 Nueva base de datos lista";
        }
        render();
      } catch (e) {
        status.innerText = "❌ Error al iniciar: " + e.message;
      }
    }

    function guardar() {
      const data = db.export();
      localStorage.setItem("db_tarjeta", JSON.stringify(Array.from(data)));
    }

    function render() {
      const mKey = viewDate.getFullYear() + '-' + String(viewDate.getMonth() + 1).padStart(2, '0');
      document.getElementById('current-month-label').innerText = viewDate.toLocaleDateString('es-AR', { month: 'long', year: 'numeric' });
      
      const res = db.exec("SELECT * FROM gastos");
      let total = 0;
      const list = document.getElementById('expenses-list');
      list.innerHTML = "";

      if (res.length > 0) {
        res[0].values.forEach(row => {
          const [id, d, m, c, ini] = row;
          const [y, mm] = ini.split('-').map(Number);
          const cuotaValor = m / c;
          
          for(let i=0; i<c; i++) {
            const fechaCuota = new Date(y, mm-1+i, 1);
            const k = fechaCuota.getFullYear() + '-' + String(fechaCuota.getMonth()+1).padStart(2, '0');
            if (k === mKey) {
              total += cuotaValor;
              list.innerHTML += `
                <div class="card-surface p-4 rounded-xl flex justify-between items-center">
                  <div>
                    <div class="font-bold">${d}</div>
                    <div class="text-[10px] text-gray-500">Cuota ${i+1} de ${c}</div>
                  </div>
                  <div class="text-right">
                    <div class="text-[#ff6b35] font-bold">$${cuotaValor.toFixed(2)}</div>
                    <button onclick="eliminar(${id})" class="text-[9px] text-red-500 uppercase font-bold mt-1">Borrar</button>
                  </div>
                </div>`;
            }
          }
        });
      }
      document.getElementById('month-total').innerText = `$${total.toFixed(2)}`;
      lucide.createIcons();
    }

    document.getElementById('expense-form').onsubmit = (e) => {
      e.preventDefault();
      db.run("INSERT INTO gastos (desc, monto, cuotas, inicio) VALUES (?,?,?,?)", 
        [document.getElementById('desc').value, document.getElementById('amount').value, document.getElementById('installments').value, document.getElementById('start-date').value]);
      guardar();
      render();
      e.target.reset();
      document.getElementById('start-date').value = new Date().toISOString().substring(0, 7);
    };

    function eliminar(id) {
      if(confirm("¿Borrar este gasto?")) {
        db.run("DELETE FROM gastos WHERE id = ?", [id]);
        guardar(); render();
      }
    }

    function cambiarMes(v) { viewDate.setMonth(viewDate.getMonth() + v); render(); }
    
    function exportarDB() {
      const blob = new Blob([db.export()], {type: "application/x-sqlite3"});
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = "mis_gastos.db"; a.click();
    }

    document.getElementById('file-input').onchange = (e) => {
      const reader = new FileReader();
      reader.onload = async function() {
        const SQL = await initSqlJs({ locateFile: file => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/${file}` });
        db = new SQL.Database(new Uint8Array(reader.result));
        guardar(); render();
      };
      reader.readAsArrayBuffer(e.target.files[0]);
    };

    document.getElementById('start-date').value = new Date().toISOString().substring(0, 7);
    iniciar();
  </script>
</body>
</html>
